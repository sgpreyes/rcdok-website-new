---
import { Image } from 'astro:assets';

const {
  name,
  img,
  logo,
  address,
  telephone,
  head,
  email,
  website,
  fbLink,
  mapLink
} = Astro.props;
---

<section class="school-profile-container">

  {img && (
    <div class="hero-image-wrapper">
      <img src={img} alt={name} class="wide-photo" />
      <div class="image-inner-shadow"></div>
    </div>
  )}

  <div class="profile-body">

    <header class="profile-header">
      <h2 class="school-name">{name}</h2>
      <div class="accent-bar"></div>
    </header>

    <div class="info-grid">

      {logo && (
        <div class="logo-item">
          <img src={logo} alt={`${name} logo`} />
        </div>
      )}

      <div class="info-column">

        {address && (
          <div class="info-item">
            <span class="label">Address</span>
            <p class="value">{address}</p>
          </div>
        )}

        {telephone && (
          <div class="info-item">
            <span class="label">Telephone</span>
            <p class="value">{telephone}</p>
          </div>
        )}

        {head && (
          <div class="info-item">
            <span class="label">Leadership</span>
            <p class="value">{head}</p>
          </div>
        )}

        {email && (
          <div class="info-item">
            <span class="label">Email</span>
            <p class="value">
              <a href={`mailto:${email}`} class="gold-link">{email}</a>
            </p>
          </div>
        )}

        {website && (
          <div class="info-item">
            <span class="label">Website</span>
            <p class="value">
              <a href={website} target="_blank" class="gold-link">
                Visit Website →
              </a>
            </p>
          </div>
        )}

        {fbLink && (
          <div class="info-item">
            <span class="label">Facebook</span>
            <p class="value">
              <a href={fbLink} target="_blank" class="gold-link">
                Official Page →
              </a>
            </p>
          </div>
        )}

        {mapLink && (
          <div class="info-item">
            <span class="label">Location Map</span>
            <p class="value">
              <a href={mapLink} target="_blank" class="gold-link">
                View on Google Maps →
              </a>
            </p>
          </div>
        )}

      </div>

    </div>

  </div>
</section>

<style>
.school-profile-container {
  background-color: var(--sl-color-gray-6);
  border: 1px solid var(--sl-color-gray-5);
  border-radius: 16px;
  overflow: hidden;
  margin: 3rem 0;
  box-shadow: var(--sl-shadow-md);
}

.hero-image-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 21 / 9;
  overflow: hidden;
}

.wide-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(.75);
  transition: transform 1s ease;
}

.school-profile-container:hover .wide-photo {
  transform: scale(1.05);
}

.image-inner-shadow {
  position: absolute;
  inset: 0;
  box-shadow: inset 0 -40px 60px rgba(0,0,0,.3);
}

.profile-body {
  padding: 3rem;
}

.school-name {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.8rem,4vw,2.5rem);
  color: var(--sl-color-white);
}

.accent-bar {
  width: 80px;
  height: 3px;
  background: #d4af37;
  margin: 1rem 0 2rem;
}

.info-grid {
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 2rem;
}

.logo-item img {
  width: 150px;
  border-radius: 8px;
}

.label {
  display:block;
  font-size:.7rem;
  letter-spacing:.15em;
  text-transform:uppercase;
  color:#d4af37;
}

.value {
  margin:0;
  color:var(--sl-color-gray-2);
}

.gold-link {
  color:#d4af37;
  text-decoration:none;
}

.gold-link:hover {
  text-decoration:underline;
}

@media (max-width:768px){

.info-grid{
grid-template-columns:1fr;
}

.logo-item{
text-align:center;
}

.profile-body{
padding:1.5rem;
}

}
</style>
