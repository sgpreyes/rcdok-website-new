---
import { Image } from 'astro:assets';
const { name, img, priest, address, contact, fbLink } = Astro.props;
---

<section class="parish-profile-container">
  <div class="hero-image-wrapper">
    <Image src={img} alt={name} class="wide-photo" />
    <div class="image-inner-shadow"></div>
  </div>

  <div class="profile-body">
    {/* Title Section */}
    <header class="profile-header">
      <h2 class="parish-name">{name}</h2>
      <div class="accent-bar"></div>
    </header>

    {/* Grid */}
    <div class="info-grid">
        <div class="info-item">
          <span class="label">Parish Priest</span>
          <p class="value">{priest}</p>
        </div>

        <div class="info-item">
          <span class="label">Location</span>
          <p class="value">{address}</p>
        </div>

        <div class="info-item">
          <span class="label">Contact</span>
          <p class="value">{contact}</p>
        </div>
        
        <div class="info-item action-item">
          <span class="label"></span> <p class="value">
            <a href={fbLink} target="_blank" class="gold-link">
              View Official Facebook Page →
            </a>
          </p>
        </div>
    </div>

    {/* History Section */}
    <div class="narrative-section">
      <h3>Our Heritage</h3>
      <div class="history-content">
        <slot />
      </div>
    </div>
  </div>
</section>

<style>
  .parish-profile-container {
    background-color: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 16px;
    overflow: hidden;
    margin: 3rem 0;
    box-shadow: var(--sl-shadow-md);
  }

  .hero-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 21 / 9;
    overflow: hidden;
  }

  .wide-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .parish-profile-container:hover .wide-photo {
    transform: scale(1.03);
  }

  .image-inner-shadow {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 -40px 60px rgba(0, 0, 0, 0.2);
  }

  .profile-body {
    padding: 3rem;
  }

  .parish-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--sl-color-white);
    margin: 0;
    line-height: 1.2;
  }

  .accent-bar {
    width: 80px;
    height: 3px;
    background: #d4af37; 
    margin: 1.5rem 0 2.5rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; 
    gap: 2rem; 
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding-bottom: 2rem;
    align-items: start; 
  }

  .info-item {
    margin: 0 !important; 
  }

  .info-column {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    margin: 0;
    padding: 0;
    gap: 2rem;
    height: 100%;
  }

  .info-item:first-child {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  .info-column > .info-item:first-child {
    margin-top: 0 !important;
  }

  .info-item:first-child {
    flex: 1; 
    margin-bottom: 2rem;
  }

  .label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #d4af37;
    margin: 0 0 0.2rem 0; 
    font-weight: 700;
    line-height: 1.2;
  }

  .value {
    font-size: 1.05rem;
    color: var(--sl-color-gray-2);
    margin: 0 !important; 
    line-height: 1.4;
    padding-top: 0.25rem; 
  }

  .gold-link {
    color: #d4af37;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .gold-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Text Area */
  .narrative-section h3 {
    font-family: 'Playfair Display', serif;
    color: var(--sl-color-white);
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .history-content {
    line-height: 1.8;
    color: var(--sl-color-gray-3);
    text-align: justify;
  }

  @media (max-width: 768px) {
    .hero-image-wrapper { aspect-ratio: 16 / 9; }
    .info-grid { grid-template-columns: 1fr; }
    .profile-body { padding: 1.5rem; }
  }
</style>