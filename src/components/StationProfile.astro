---
// src/components/StationProfile.astro
import { Image } from 'astro:assets';
const { name, img, priest, address, contact, fbLink } = Astro.props;
---

<section class="station-profile-wrapper">
  <div class="station-card">
    <div class="visual-side">
      <Image src={img} alt={name} class="station-photo" />
      <div class="photo-vignette"></div>
      <div class="name-overlay">
        <span class="category-tag">Mission Station</span>
        <h2 class="station-display-name">{name}</h2>
      </div>
    </div>

    <div class="details-side">
      <div class="accent-top"></div>
      
      <div class="menu-section">
        <h4 class="menu-label">Ledership</h4>
        <p class="menu-value">{priest || "Diocese of Kalookan"}</p>
      </div>

      <div class="menu-section">
        <h4 class="menu-label">Community Location</h4>
        <p class="menu-value">{address}</p>
      </div>

      <div class="menu-section">
        <h4 class="menu-label">Contact Details</h4>
        <p class="menu-value">{contact || "Through community page"}</p>
      </div>

      <div class="menu-section history-slot">
        <h4 class="menu-label">About the Station</h4>
        <div class="slot-content">
          <slot />
        </div>
      </div>

      <div class="action-footer">
        <a href={fbLink} target="_blank" class="gold-action-link">
          Official Community Page <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .station-profile-wrapper {
    margin: 4rem 0;
  }

  .station-card {
    display: flex;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px; /* Sharper corners for a "Menu" look */
    overflow: hidden;
    min-height: 600px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.15);
  }

  /* Visual Side */
  .visual-side {
    flex: 1.2;
    position: relative;
    overflow: hidden;
  }

  .station-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s ease;
  }

  .station-card:hover .station-photo {
    transform: scale(1.05);
  }

  .photo-vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.4), transparent);
  }

  .name-overlay {
    position: absolute;
    bottom: 3rem;
    left: 3rem;
    right: 2rem;
    color: white;
    z-index: 2;
  }

  .category-tag {
    color: #d4af37;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .station-display-name {
    font-family: 'Playfair Display', serif;
    font-size: 3rem;
    line-height: 1.1;
    margin-top: 0.5rem;
    text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
    color: white;
  }

  /* Details Side */
  .details-side {
    flex: 0.8;
    padding: 4rem 3rem;
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--sl-color-gray-6);
  }

  .accent-top {
    position: absolute;
    top: 0;
    right: 0;
    width: 100px;
    height: 5px;
    background: #d4af37;
  }

  .menu-section {
    margin-bottom: 2.5rem;
  }

  .menu-label {
    color: #d4af37;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .menu-value {
    font-size: 1.1rem;
    color: var(--sl-color-gray-2);
    margin: 0;
    font-family: 'Inter', sans-serif;
  }

  .slot-content {
    font-style: italic;
    line-height: 1.6;
    color: var(--sl-color-gray-3);
    font-size: 0.95rem;
  }

  .gold-action-link {
    margin-top: auto;
    color: #d4af37;
    text-decoration: none;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .gold-action-link:hover {
    border-bottom: 1px solid #d4af37;
  }

  .gold-action-link .arrow {
    margin-left: 0.5rem;
    transition: transform 0.3s ease;
    display: inline-block;
  }

  .gold-action-link:hover .arrow {
    transform: translateX(5px);
  }

  @media (max-width: 1024px) {
    .station-card { flex-direction: column; }
    .station-display-name { font-size: 2rem; }
    .visual-side { height: 400px; }
  }
</style>